{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,   // tsup handles actual emit; outDir kept for IDE/tooling awareness
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src/**/*"]
}
